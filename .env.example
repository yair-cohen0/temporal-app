# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=workflow-default

# MongoDB (application database — external, not in docker-compose)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=workflow_engine
MONGO_OUTBOX_COLLECTION=outbox

# API server
PORT=3000

# Logging
LOG_LEVEL=info
